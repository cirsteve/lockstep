# Lockstep environment variables — template.
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# `.env` is gitignored (see .gitignore). Never commit real keys.
# Both Python (via pytest-dotenv / dotenv) and the TS storage service
# (via the `dotenv` package) load from this file at the repo root.

# ---------------------------------------------------------------------------
# 0G Galileo testnet — required for Track A (storage real path) and §C.1
# (iNFT smoke). Wallet generation + faucet claim documented in
# spec/day-04.md §P.1.
# ---------------------------------------------------------------------------

# Hex-encoded private key for the Galileo dev wallet. Required at boot for
# the TS storage service and for Hardhat deploy in PR #7. Keep secret.
LOCKSTEP_0G_PRIVATE_KEY=0x_replace_with_real_key

# RPC + indexer URLs. Defaults below match config/galileo.yaml; only set
# these if you need to override (e.g. Galileo network rotation).
LOCKSTEP_0G_GALILEO_RPC=https://evmrpc-testnet.0g.ai
LOCKSTEP_0G_GALILEO_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# ---------------------------------------------------------------------------
# TS storage service (PR #5) — local dev defaults.
# ---------------------------------------------------------------------------

# Where the Python RealStorageAdapter looks for the TS service. Default
# matches `npm run dev` in services/storage-ts/. Only override for remote /
# Docker setups — never expose this beyond localhost (the service holds
# the wallet key; see services/storage-ts/README.md).
LOCKSTEP_0G_STORAGE_SERVICE_URL=http://localhost:7878

# TS service binding port. Match the SERVICE_URL above.
LOCKSTEP_0G_STORAGE_PORT=7878

# ---------------------------------------------------------------------------
# Test gates.
# ---------------------------------------------------------------------------

# Set to "1" to run the live-Galileo conformance branch in
# tests/substrate/test_storage_conformance.py. Leave blank for the default
# (mock-only) test run. CI doesn't set this; local devs set it when they
# want to exercise the real path.
LOCKSTEP_TEST_REAL_STORAGE=

# ---------------------------------------------------------------------------
# Day 5+ — uncomment when these tracks land.
# ---------------------------------------------------------------------------

# KeeperHub MCP — required for §C.3 smoke test.
# LOCKSTEP_KEEPERHUB_URL=
# LOCKSTEP_KEEPERHUB_AUTH_TOKEN=
